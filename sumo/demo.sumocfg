<configuration>
    <input>
        <net-file value="map.net.xml"/>
        <route-files value="random_demand.rou.xml"/>
    </input>
    <time>
        <step-length value="0.05"/>
    </time>
    <processing>
        <collision.action value="warn"/>
        <no-warnings value="true"/>
    </processing>
</configuration>